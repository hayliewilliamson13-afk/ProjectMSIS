<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ProjectMSIS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ProjectMSIS.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-dark bg-danger px-4 py-3">
            <span class="navbar-brand fw-bold fs-4 text-uppercase">Costco Wholesale</span>
            <span class="badge bg-light text-danger fw-semibold">Coming Soon</span>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="bg-danger text-center py-3">
        <p class="text-white small mb-1 opacity-75">&copy; @DateTime.Now.Year Costco Wholesale Corporation. All rights reserved.</p>
        <div class="d-flex justify-content-center gap-3">
            <a href="#" class="text-white small text-decoration-none opacity-75">Privacy Policy</a>
            <a href="#" class="text-white small text-decoration-none opacity-75">Terms of Use</a>
            <a href="#" class="text-white small text-decoration-none opacity-75">Contact Us</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>